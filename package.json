{
  "name": "tracemap",
  "version": "0.1.0",
  "private": true,
  "description": "TraceMap - OTEL-derived service topology and observability dashboard",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "migrate": "npm run migrate --workspace server",
    "simulate": "cd server && tsx src/sim/simulate.ts",
    "test": "npm run test --workspace server && npm run test --workspace web",
    "build": "npm run build --workspace server && npm run build --workspace web",
    "typecheck": "npm-run-all typecheck:server typecheck:web",
    "typecheck:server": "npm run typecheck --workspace server",
    "typecheck:web": "npm run typecheck --workspace web",
    "sandcastle": "npx tsx .sandcastle/main.mts",
    "sandcastle:loop": "bash scripts/sandcastle-loop.sh"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.12.0",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "protobufjs@7.6.3": true
  }
}
